{
  "info": {
    "name": "Dinosaur Service — Froneus Challenge (Full)",
    "description": "Complete collection: POST, GET, PUT, DELETE with all test cases",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080", "type": "string" },
    { "key": "dino_id",  "value": "1", "type": "string",
      "description": "ID from POST — auto-saved by test script" }
  ],
  "item": [
    {
      "name": "🟢 POST — Create dinosaur",
      "item": [
        {
          "name": "✅ POST success (ALIVE)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 201) {",
                "    const body = pm.response.json();",
                "    pm.collectionVariables.set('dino_id', body.id);",
                "    console.log('Saved dino_id:', body.id);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Accept",          "value": "application/json" },
              { "key": "Idempotency-Key", "value": "idem-a1b2c3d4-0001-0001-0001-ef1234567890" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Protoceratops\",\n  \"species\": \"Protoceratopsidae\",\n  \"discoveryDate\": \"1922-07-15T00:00:00\",\n  \"extinctionDate\": \"2027-07-15T23:59:59\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur", "host": ["{{base_url}}"], "path": ["v1","dinosaur"] }
          }
        },
        {
          "name": "✅ POST success 2 (for pagination)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Deinonychus\",\n  \"species\": \"Dromaeosauridae\",\n  \"discoveryDate\": \"1969-03-20T00:00:00\",\n  \"extinctionDate\": \"2026-03-20T23:59:59\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur", "host": ["{{base_url}}"], "path": ["v1","dinosaur"] }
          }
        },
        {
          "name": "🔁 POST idempotency — same key replay",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",    "value": "application/json" },
              { "key": "Accept",          "value": "application/json" },
              { "key": "Idempotency-Key", "value": "idem-a1b2c3d4-0001-0001-0001-ef1234567890" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Protoceratops\",\n  \"species\": \"Protoceratopsidae\",\n  \"discoveryDate\": \"1922-07-15T00:00:00\",\n  \"extinctionDate\": \"2027-07-15T23:59:59\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur", "host": ["{{base_url}}"], "path": ["v1","dinosaur"] }
          }
        },
        {
          "name": "❌ POST duplicate name → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Protoceratops\",\n  \"species\": \"Protoceratopsidae\",\n  \"discoveryDate\": \"1922-07-15T00:00:00\",\n  \"extinctionDate\": \"2027-07-15T23:59:59\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur", "host": ["{{base_url}}"], "path": ["v1","dinosaur"] }
          }
        },
        {
          "name": "❌ POST invalid dates → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"DinoInvalidDate\",\n  \"species\": \"Theropod\",\n  \"discoveryDate\": \"2025-01-01T00:00:00\",\n  \"extinctionDate\": \"2020-01-01T00:00:00\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur", "host": ["{{base_url}}"], "path": ["v1","dinosaur"] }
          }
        },
        {
          "name": "❌ POST malformed JSON → 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{ invalid json }", "options": { "raw": { "language": "json" } } },
            "url": { "raw": "{{base_url}}/v1/dinosaur", "host": ["{{base_url}}"], "path": ["v1","dinosaur"] }
          }
        }
      ]
    },
    {
      "name": "🔵 GET — List & detail",
      "item": [
        {
          "name": "✅ GET all — page 1 (10 per page)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/v1/dinosaur?page=1&pageSize=10",
              "host": ["{{base_url}}"], "path": ["v1","dinosaur"],
              "query": [{ "key": "page", "value": "1" }, { "key": "pageSize", "value": "10" }]
            }
          }
        },
        {
          "name": "✅ GET all — page 2",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/v1/dinosaur?page=2&pageSize=10",
              "host": ["{{base_url}}"], "path": ["v1","dinosaur"],
              "query": [{ "key": "page", "value": "2" }, { "key": "pageSize", "value": "10" }]
            }
          }
        },
        {
          "name": "✅ GET by ID (auto dino_id)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/v1/dinosaur/{{dino_id}}", "host": ["{{base_url}}"], "path": ["v1","dinosaur","{{dino_id}}"] }
          }
        },
        {
          "name": "✅ GET seed — Tyrannosaurus Rex (id=1)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/v1/dinosaur/1", "host": ["{{base_url}}"], "path": ["v1","dinosaur","1"] }
          }
        },
        {
          "name": "❌ GET by ID not found → 404",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/v1/dinosaur/99999", "host": ["{{base_url}}"], "path": ["v1","dinosaur","99999"] }
          }
        }
      ]
    },
    {
      "name": "🟡 PUT — Update dinosaur",
      "item": [
        {
          "name": "✅ PUT update name and species",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Protoceratops Updated\",\n  \"species\": \"Protoceratopsidae\",\n  \"discoveryDate\": \"1922-07-15T00:00:00\",\n  \"extinctionDate\": \"2027-07-15T23:59:59\",\n  \"status\": \"ALIVE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur/{{dino_id}}", "host": ["{{base_url}}"], "path": ["v1","dinosaur","{{dino_id}}"] }
          }
        },
        {
          "name": "✅ PUT change status to ENDANGERED",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Protoceratops Updated\",\n  \"species\": \"Protoceratopsidae\",\n  \"discoveryDate\": \"1922-07-15T00:00:00\",\n  \"extinctionDate\": \"2027-07-15T23:59:59\",\n  \"status\": \"ENDANGERED\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur/{{dino_id}}", "host": ["{{base_url}}"], "path": ["v1","dinosaur","{{dino_id}}"] }
          }
        },
        {
          "name": "❌ PUT EXTINCT dinosaur → 400 (use seed id=2 Velociraptor EXTINCT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Velociraptor\",\n  \"species\": \"Dromaeosauridae\",\n  \"discoveryDate\": \"1924-05-01T00:00:00\",\n  \"extinctionDate\": \"2023-06-15T23:59:59\",\n  \"status\": \"ALIVE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur/2", "host": ["{{base_url}}"], "path": ["v1","dinosaur","2"] }
          }
        },
        {
          "name": "❌ PUT duplicate name → 400",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Triceratops\",\n  \"species\": \"Protoceratopsidae\",\n  \"discoveryDate\": \"1922-07-15T00:00:00\",\n  \"extinctionDate\": \"2027-07-15T23:59:59\",\n  \"status\": \"ALIVE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur/{{dino_id}}", "host": ["{{base_url}}"], "path": ["v1","dinosaur","{{dino_id}}"] }
          }
        },
        {
          "name": "❌ PUT not found → 404",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Unknown\",\n  \"species\": \"Unknown\",\n  \"discoveryDate\": \"2000-01-01T00:00:00\",\n  \"extinctionDate\": \"2030-01-01T00:00:00\",\n  \"status\": \"ALIVE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/v1/dinosaur/99999", "host": ["{{base_url}}"], "path": ["v1","dinosaur","99999"] }
          }
        }
      ]
    },
    {
      "name": "🔴 DELETE — Soft delete",
      "item": [
        {
          "name": "✅ DELETE success → 200 with message",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/v1/dinosaur/{{dino_id}}", "host": ["{{base_url}}"], "path": ["v1","dinosaur","{{dino_id}}"] }
          }
        },
        {
          "name": "✅ GET after DELETE — not found (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/v1/dinosaur/{{dino_id}}", "host": ["{{base_url}}"], "path": ["v1","dinosaur","{{dino_id}}"] }
          }
        },
        {
          "name": "❌ DELETE not found → 404",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/v1/dinosaur/99999", "host": ["{{base_url}}"], "path": ["v1","dinosaur","99999"] }
          }
        }
      ]
    },
    {
      "name": "💚 Health & Circuit Breaker",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/actuator/health", "host": ["{{base_url}}"], "path": ["actuator","health"] }
          }
        },
        {
          "name": "Circuit Breakers Status",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{base_url}}/actuator/circuitbreakers", "host": ["{{base_url}}"], "path": ["actuator","circuitbreakers"] }
          }
        }
      ]
    }
  ]
}
