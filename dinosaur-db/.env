# =============================================================================
# Variables de entorno — Challenge Froneus
# Copiar este archivo como .env y ajustar valores si es necesario.
# En producción: usar secrets reales y NO commitear este archivo.
# =============================================================================

# PostgreSQL
POSTGRES_USER=froneus
POSTGRES_PASSWORD=froneus_pass
POSTGRES_DB=froneus_db
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Spring Boot (referencia para la app Java)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/froneus_db
# SPRING_DATASOURCE_USERNAME=froneus
# SPRING_DATASOURCE_PASSWORD=froneus_pass
# SPRING_REDIS_HOST=localhost
# SPRING_REDIS_PORT=6379
